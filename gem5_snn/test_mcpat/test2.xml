<?xml version="1.0" ?>
<component id="root" name="root">
	<component id="system" name="system">
		<!-- Основные параметры системы -->
		<param name="number_of_cores" value="1"/>
		<param name="number_of_L1Directories" value="0"/>  <!-- Нет директорий когерентности -->
		<param name="number_of_L2Directories" value="0"/>
		<param name="number_of_L2s" value="0"/>  <!-- Нет L2 кэша -->
		<param name="Private_L2" value="0"/>
		<param name="number_of_L3s" value="0"/>
		<param name="number_of_NoCs" value="1"/>
		<param name="homogeneous_cores" value="1"/>
		<param name="homogeneous_L2s" value="1"/>
		<param name="homogeneous_L1Directories" value="1"/>
		<param name="homogeneous_L2Directories" value="1"/>
		<param name="homogeneous_L3s" value="1"/>
		<param name="homogeneous_ccs" value="1"/>
		<param name="homogeneous_NoCs" value="1"/>

		<!-- Технологические параметры -->
		<param name="core_tech_node" value="40"/>  <!-- 40nm техпроцесс -->
		<param name="target_core_clockrate" value="1000"/>  <!-- 1 GHz -->
		<param name="temperature" value="340"/>  <!-- 67°C -->
		<param name="number_cache_levels" value="1"/>  <!-- Только L1 кэш -->
		<param name="interconnect_projection_type" value="1"/>
		<param name="device_type" value="2"/>  <!-- Low Operating Power -->
		<param name="longer_channel_device" value="1"/>
		<param name="Embedded" value="1"/>  <!-- Встраиваемый ARM процессор -->
		<param name="opt_clockrate" value="1"/>

		<!-- Архитектурные параметры ARMv7-A -->
		<param name="machine_bits" value="32"/>
		<param name="virtual_address_width" value="32"/>
		<param name="physical_address_width" value="32"/>
		<param name="virtual_memory_page_size" value="4096"/>

		<!-- Статистика выполнения -->
		<stat name="total_cycles" value="100000"/>
		<stat name="idle_cycles" value="0"/>
		<stat name="busy_cycles" value="100000"/>

		<!-- *********************** Ядро ******************* -->
		<component id="system.core0" name="core0">
			<param name="clock_rate" value="1000"/>
			<param name="opt_local" value="0"/>
			<param name="instruction_length" value="32"/>  <!-- ARM 32-bit -->
			<param name="opcode_width" value="7"/>
			<param name="arm" value="1"/>  <!-- ARM архитектура -->
			<param name="micro_opcode_width" value="8"/>
			<param name="machine_type" value="1"/>  <!-- inorder процессор (TimingSimpleCPU) -->
			<param name="number_hardware_threads" value="1"/>

			<!-- Конвейерные параметры -->
			<param name="fetch_width" value="2"/>
			<param name="number_instruction_fetch_ports" value="1"/>
			<param name="decode_width" value="2"/>
			<param name="issue_width" value="2"/>  <!-- In-order, ограниченный issue -->
			<param name="peak_issue_width" value="4"/>
			<param name="commit_width" value="2"/>
			<param name="fp_issue_width" value="1"/>
			<param name="prediction_width" value="1"/>

			<!-- Глубина конвейера (ARMv7-A типично) -->
			<param name="pipelines_per_core" value="1,1"/>
			<param name="pipeline_depth" value="8,8"/>

			<!-- Исполнительные блоки -->
			<param name="ALU_per_core" value="2"/>  <!-- Типично для ARM -->
			<param name="MUL_per_core" value="1"/>
			<param name="FPU_per_core" value="1"/>  <!-- VFPv3 для ARMv7-A -->

			<!-- Буферы -->
			<param name="instruction_buffer_size" value="16"/>
			<param name="decoded_stream_buffer_size" value="8"/>
			<param name="instruction_window_scheme" value="0"/>
			<param name="instruction_window_size" value="8"/>  <!-- In-order, небольшое окно -->
			<param name="fp_instruction_window_size" value="8"/>
			<param name="ROB_size" value="0"/>  <!-- Нет ROB для in-order -->

			<!-- Регистровые файлы (ARMv7-A) -->
			<param name="archi_Regs_IRF_size" value="16"/>  <!-- 16 регистров общего назначения -->
			<param name="archi_Regs_FRF_size" value="32"/>  <!-- 32 FPU регистра -->
			<param name="phy_Regs_IRF_size" value="16"/>
			<param name="phy_Regs_FRF_size" value="32"/>

			<!-- Переименование (не используется для in-order) -->
			<param name="rename_scheme" value="0"/>
			<param name="checkpoint_depth" value="1"/>
			<param name="register_windows_size" value="0"/>

			<!-- Memory subsystem -->
			<param name="LSU_order" value="inorder"/>
			<param name="store_buffer_size" value="4"/>
			<param name="load_buffer_size" value="4"/>
			<param name="memory_ports" value="1"/>
			<param name="RAS_size" value="4"/>

			<!-- Статистика выполнения (настраивайте под вашу программу) -->
			<stat name="total_instructions" value="400000"/>
			<stat name="int_instructions" value="300000"/>
			<stat name="fp_instructions" value="50000"/>
			<stat name="branch_instructions" value="50000"/>
			<stat name="branch_mispredictions" value="5000"/>
			<stat name="load_instructions" value="100000"/>
			<stat name="store_instructions" value="50000"/>
			<stat name="committed_instructions" value="400000"/>
			<stat name="committed_int_instructions" value="300000"/>
			<stat name="committed_fp_instructions" value="50000"/>
			<stat name="pipeline_duty_cycle" value="0.8"/>

			<!-- Предсказатель ветвлений -->
			<component id="system.core0.predictor" name="PBT">
				<param name="local_predictor_size" value="10,3"/>
				<param name="local_predictor_entries" value="4"/>
				<param name="global_predictor_entries" value="1024"/>  <!-- Уменьшен для встраиваемости -->
				<param name="global_predictor_bits" value="2"/>
				<param name="chooser_predictor_entries" value="1024"/>
				<param name="chooser_predictor_bits" value="2"/>
			</component>

			<!-- ITLB -->
			<component id="system.core0.itlb" name="itlb">
				<param name="number_entries" value="32"/>  <!-- ARM типично -->
				<stat name="total_accesses" value="200000"/>
				<stat name="total_misses" value="1000"/>
				<stat name="conflicts" value="100"/>
			</component>

			<!-- L1 I-Cache (8 kB, 4-way) -->
			<component id="system.core0.icache" name="icache">
				<param name="icache_config" value="8192,64,4,1,1,1,32,0"/>
				<!-- 8kB, 64B блоки, 4-way, 1 банк, throughput=1, latency=1, 32B output, no write -->
				<param name="buffer_sizes" value="2,2,2,0"/>
				<stat name="read_accesses" value="200000"/>
				<stat name="read_misses" value="10000"/>
				<stat name="conflicts" value="500"/>
			</component>

			<!-- DTLB -->
			<component id="system.core0.dtlb" name="dtlb">
				<param name="number_entries" value="32"/>
				<stat name="total_accesses" value="300000"/>
				<stat name="total_misses" value="2000"/>
				<stat name="conflicts" value="200"/>
			</component>

			<!-- L1 D-Cache (8 kB, 4-way) -->
			<component id="system.core0.dcache" name="dcache">
				<param name="dcache_config" value="8192,64,4,1,1,1,32,1"/>
				<!-- 8kB, 64B блоки, 4-way, write-back -->
				<param name="buffer_sizes" value="4,4,2,4"/>
				<stat name="read_accesses" value="300000"/>
				<stat name="write_accesses" value="100000"/>
				<stat name="read_misses" value="15000"/>
				<stat name="write_misses" value="5000"/>
				<stat name="conflicts" value="500"/>
			</component>

			<!-- BTB -->
			<param name="number_of_BTB" value="1"/>
			<component id="system.core0.BTB" name="BTB">
				<param name="BTB_config" value="512,4,2,1,1,1"/>
				<stat name="read_accesses" value="200000"/>
				<stat name="write_accesses" value="10000"/>
			</component>
		</component>

		<!-- Нет L1 директорий, L2, L3 кэшей -->

		<!-- NoC/шина -->
		<component id="system.NoC0" name="noc0">
			<param name="clockrate" value="1000"/>
			<param name="type" value="0"/>  <!-- шина -->
			<param name="horizontal_nodes" value="1"/>
			<param name="vertical_nodes" value="1"/>
			<param name="has_global_link" value="0"/>
			<param name="link_throughput" value="1"/>
			<param name="link_latency" value="1"/>
			<param name="input_ports" value="1"/>
			<param name="output_ports" value="1"/>
			<param name="flit_bits" value="64"/>
			<param name="chip_coverage" value="1"/>
			<param name="link_routing_over_percentage" value="0.5"/>
			<stat name="total_accesses" value="400000"/>
			<stat name="duty_cycle" value="0.5"/>
		</component>

		<!-- Контроллер памяти (DDR4) -->
		<component id="system.mc" name="mc">
			<param name="type" value="1"/>  <!-- low power -->
			<param name="mc_clock" value="400"/>  <!-- 400 MHz -->
			<param name="peak_transfer_rate" value="6400"/>  <!-- MB/s -->
			<param name="block_size" value="64"/>
			<param name="number_mcs" value="1"/>
			<param name="memory_channels_per_mc" value="1"/>
			<param name="number_ranks" value="1"/>
			<param name="req_window_size_per_channel" value="32"/>
			<param name="IO_buffer_size_per_channel" value="32"/>
			<param name="databus_width" value="64"/>
			<param name="addressbus_width" value="32"/>
			<stat name="memory_accesses" value="20000"/>
			<stat name="memory_reads" value="10000"/>
			<stat name="memory_writes" value="10000"/>
			<param name="withPHY" value="1"/>
		</component>

		<!-- Отключаем ненужные компоненты -->
		<component id="system.niu" name="niu">
			<param name="type" value="1"/>
			<param name="clockrate" value="350"/>
			<param name="number_units" value="0"/>
			<stat name="duty_cycle" value="0"/>
			<stat name="total_load_perc" value="0"/>
		</component>

		<component id="system.pcie" name="pcie">
			<param name="type" value="1"/>
			<param name="withPHY" value="1"/>
			<param name="clockrate" value="350"/>
			<param name="number_units" value="0"/>
			<param name="num_channels" value="0"/>
			<stat name="duty_cycle" value="0"/>
			<stat name="total_load_perc" value="0"/>
		</component>

		<component id="system.flashc" name="flashc">
			<param name="number_flashcs" value="0"/>
			<param name="type" value="1"/>
			<param name="withPHY" value="1"/>
			<param name="peak_transfer_rate" value="200"/>
			<stat name="duty_cycle" value="0"/>
			<stat name="total_load_perc" value="0"/>
		</component>
	</component>
</component>